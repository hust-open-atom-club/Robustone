}""",
        "V1R_FR": """fn extract_V1R_FR(word: u32) -> Vec<Operand> {
    let xd = word & 0x1F;
    let fd = (word >> 5) & 0x1F;
    vec![Operand::Register { register: RegisterId::loongarch(xd + 64) }, Operand::Register { register: RegisterId::loongarch(fd + 32) }]
}""",
        "MEM": """fn extract_MEM(word: u32) -> Vec<Operand> {
    let rd = word & 0x1F;
    let rj = (word >> 5) & 0x1F;
    let imm = sign_extend((word >> 10) & 0xFFF, 12);
    vec![Operand::Register { register: RegisterId::loongarch(rd) }, Operand::Register { register: RegisterId::loongarch(rj) }, Operand::Immediate { value: imm }]
}""",
        "F_MEM": """fn extract_F_MEM(word: u32) -> Vec<Operand> {
    let fd = word & 0x1F;
    let rj = (word >> 5) & 0x1F;
