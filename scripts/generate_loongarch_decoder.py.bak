    vec![Operand::Register { register: RegisterId::loongarch(fd + 32) }, Operand::Register { register: RegisterId::loongarch(rj) }, Operand::Immediate { value: imm }]
}""",
        "MEM14": """fn extract_MEM14(word: u32) -> Vec<Operand> {
    let rd = word & 0x1F;
    let rj = (word >> 5) & 0x1F;
    let imm = sign_extend((word >> 10) & 0x3FFF, 14) << 2;
    vec![Operand::Register { register: RegisterId::loongarch(rd) }, Operand::Register { register: RegisterId::loongarch(rj) }, Operand::Immediate { value: imm }]
}""",


        "2R_SYS": """fn extract_2R_SYS(word: u32) -> Vec<Operand> {
    let rd = word & 0x1F;
    let rj = (word >> 5) & 0x1F;
    vec![Operand::Register { register: RegisterId::loongarch(rd) }, Operand::Register { register: RegisterId::loongarch(rj) }]
}""",
        "1RI20_SYS": """fn extract_1RI20_SYS(word: u32) -> Vec<Operand> {
    let rd = word & 0x1F;
    let imm = sign_extend((word >> 5) & 0xFFFFF, 20);
    vec![Operand::Register { register: RegisterId::loongarch(rd) }, Operand::Immediate { value: imm }]
}""",

        "3R_SYS": """fn extract_3R_SYS(word: u32) -> Vec<Operand> {
    let rd = word & 0x1F;
    let rj = (word >> 5) & 0x1F;
    let imm = (word >> 10) & 0x7FFF;
    vec![Operand::Register { register: RegisterId::loongarch(rd) }, Operand::Register { register: RegisterId::loongarch(rj) }, Operand::Immediate { value: imm as i64 }]
}""",
        "V2R_MEM": """fn extract_V2R_MEM(word: u32) -> Vec<Operand> {
    let xd = word & 0x1F;
    let rj = (word >> 5) & 0x1F;
    let rk = (word >> 10) & 0x1F;
    vec![Operand::Register { register: RegisterId::loongarch(xd + 64) }, Operand::Register { register: RegisterId::loongarch(rj) }, Operand::Register { register: RegisterId::loongarch(rk) }]
}""",
    }

    used_fmts = set()
    for word in word_to_data:
        mnemonic, fmt, operands = word_to_data[word]
        used_fmts.add(fmt)

    for fmt in sorted(used_fmts):
        if fmt in extraction_funcs:
            lines.append(extraction_funcs[fmt])
            lines.append("")
        elif fmt == "UNKNOWN":
            lines.append("""fn extract_UNKNOWN(_word: u32) -> Vec<Operand> {
    vec![]
}""")
            lines.append("")
        else:
            lines.append(f"""fn extract_{fmt}(word: u32) -> Vec<Operand> {{
    // TODO: implement {fmt} extraction
    vec![]
}}""")
            lines.append("")

    return "\n".join(lines)


def generate_decoder():
    yaml_dir = Path('third_party/capstone/tests/MC/LoongArch')
    word_to_data: Dict[int, Tuple[str, str, List[str]]] = {}

    for yaml_file in sorted(yaml_dir.rglob('*.yaml')):
        try:
            with yaml_file.open('r', encoding='utf-8') as fh:
                data = yaml.safe_load(fh)
        except yaml.YAMLError:
            continue
        if not isinstance(data, dict):
            continue
        for test_case in data.get('test_cases', []):
            inp = test_case.get('input', {})
            expected = test_case.get('expected', {})
            insns = expected.get('insns', [])
            if not insns:
                continue
            byte_list = inp.get('bytes', [])
            if len(byte_list) != 4:
                continue
            word = int.from_bytes(byte_list, byteorder='little')
            asm_text = insns[0].get('asm_text', '')
            mnemonic, operands = parse_operands(asm_text)
            op_types = tuple(operand_type(op) for op in operands)
            fmt = classify_instruction(mnemonic, op_types, word)

            if word in word_to_data:
                existing = word_to_data[word]
                if existing[0] != mnemonic:
                    print(f"WARNING: word 0x{word:08X} maps to both {existing[0]} and {mnemonic}")
            else:
                word_to_data[word] = (mnemonic, fmt, operands)

    print(f"Total unique words: {len(word_to_data)}")

    rust_code = generate_rust_code(word_to_data)

    output_path = Path('robustone-loongarch/src/decoder_generated.rs')
    output_path.write_text(rust_code)
    print(f"Generated {output_path}")


if __name__ == "__main__":
    generate_decoder()
